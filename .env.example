# ─────────────────────────────────────────────────────────────────────────────
# Token-reduction rig — environment template.
#
#   1. Copy this file:            cp .env.example .env
#   2. Put your REAL key in .env  (never here — .env is gitignored).
#   3. Python side (proxy.py / ab_runner.py) auto-loads .env via `import rig_env`.
#   4. Agent side: the `mini` CLI is a separate process, so source the file into
#      your shell before launching it:   source .env
#      (these lines use `export`, so sourcing exports them to the mini subprocess).
#
# A shell `export` always overrides the matching line here.
# ─────────────────────────────────────────────────────────────────────────────

# --- Provider key (the only thing you MUST edit) -----------------------------
# OpenAI keys start with "sk-". Forwarded agent -> proxy -> upstream, and read
# directly by ab_runner.py.
export OPENAI_API_KEY=sk-REPLACE_ME

# --- Where the AGENT sends requests: the local proxy (leave as-is) -----------
export OPENAI_API_BASE=http://localhost:8787/v1

# --- Where the PROXY forwards: the hosted provider's OpenAI-compatible API ----
#   OpenAI:    https://api.openai.com/v1
#   Anthropic: https://api.anthropic.com/v1   (OpenAI-compat endpoint)
#   Local:     http://localhost:11434/v1      (Ollama — set this to go back local)
export RIG_UPSTREAM_BASE=https://api.openai.com/v1

# --- Active transform: identity | dedup | prune ------------------------------
export RIG_TRANSFORM=identity

# --- mini-swe-agent: don't crash on models litellm can't price ---------------
export MSWEA_COST_TRACKING=ignore_errors

# --- Optional: uncomment to capture request bodies for ab_runner replay ------
# export RIG_DUMP=reqs.jsonl

# --- Optional: log-file overrides (defaults below are already used) ----------
# export RIG_LOG=rig_calls.jsonl
# export RIG_AB_LOG=ab_results.jsonl
